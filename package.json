{
  "name": "podium",
  "displayName": "Podium — Multi-Agent Stage for Claude Code",
  "description": "Orchestrate multi-agent Claude teams from one stage — leader + worker panes with structured routing, idle detection, team snapshots, and dissolve-with-summary. Or run a solo Claude Code session in a rich Webview tab. No external multiplexer required.",
  "version": "0.8.9",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "agent",
    "multi-agent",
    "orchestration",
    "team",
    "terminal",
    "webview",
    "node-pty"
  ],
  "publisher": "rockuen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rockuen/podium"
  },
  "icon": "icons/icon-128.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeCodeLauncher.open",
        "title": "Open Claude Code",
        "icon": {
          "light": "./icons/claude-robot.svg",
          "dark": "./icons/claude-robot.svg"
        },
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.renameTab",
        "title": "Rename Claude Code Tab",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.refreshSessions",
        "title": "%refreshSessions%",
        "icon": "$(refresh)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.resumeSession",
        "title": "%resumeSession%",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveToGroup",
        "title": "Move to Group...",
        "icon": "$(folder)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.renameGroup",
        "title": "Rename Group",
        "icon": "$(edit)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.deleteGroup",
        "title": "Delete Group",
        "icon": "$(trash)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.trashSession",
        "title": "Delete",
        "icon": "$(trash)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.restoreSession",
        "title": "Restore",
        "icon": "$(history)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.emptyTrash",
        "title": "Empty Trash",
        "icon": "$(close-all)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveSessionUp",
        "title": "Move Up",
        "icon": "$(arrow-up)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveSessionDown",
        "title": "Move Down",
        "icon": "$(arrow-down)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveUnderSession",
        "title": "Nest Under Session...",
        "icon": "$(list-tree)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.removeSessionParent",
        "title": "Unnest (Move to Top Level)",
        "icon": "$(arrow-left)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveGroupUp",
        "title": "Move Group Up",
        "icon": "$(arrow-up)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveGroupDown",
        "title": "Move Group Down",
        "icon": "$(arrow-down)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.session.filter",
        "title": "Filter Sessions",
        "icon": "$(filter)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.session.clearFilter",
        "title": "Clear Session Filter",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.session.openDir",
        "title": "Open Session Directory",
        "icon": "$(folder-opened)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.podium.liveTest",
        "title": "Live Multi-Pane Test (v2.7.0 prototype — 2 Claudes)",
        "icon": "$(beaker)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.orchestrate",
        "title": "Orchestrated Team (v2.7.2 — leader + 2 workers)",
        "icon": "$(organization)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.orchestrate.resume",
        "title": "Orchestrated Team — Resume Leader Session (v2.7.12)",
        "icon": "$(history)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.dissolve",
        "title": "Dissolve Team (v2.7.8 — summarize workers, kill panes, inject into leader)",
        "icon": "$(close-all)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.summonTeam",
        "title": "Summon Team (extend current Claude session with workers)",
        "icon": "$(organization)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.pause",
        "title": "Pause Routing",
        "icon": "$(debug-pause)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.resume",
        "title": "Resume Routing",
        "icon": "$(debug-start)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.resetRound",
        "title": "Reset Round Counter",
        "icon": "$(refresh)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.snapshot.save",
        "title": "Save Team Snapshot (v2.7.19)",
        "icon": "$(save)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.snapshot.load",
        "title": "Open Saved Team... (v2.7.19)",
        "icon": "$(folder-opened)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.snapshot.rename",
        "title": "Rename Saved Team... (v2.7.21)",
        "icon": "$(edit)",
        "category": "Podium"
      },
      {
        "command": "claudeCodeLauncher.podium.worker.add",
        "title": "Podium: Add Worker",
        "category": "Podium",
        "icon": "$(add)"
      },
      {
        "command": "claudeCodeLauncher.podium.worker.remove",
        "title": "Podium: Remove Worker",
        "category": "Podium",
        "icon": "$(close)"
      },
      {
        "command": "claudeCodeLauncher.podium.worker.rename",
        "title": "Podium: Rename Worker",
        "category": "Podium",
        "icon": "$(edit)"
      },
      {
        "command": "claudeCodeLauncher.podium.enter",
        "title": "Enter Podium Mode",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.podium.exit",
        "title": "Exit Podium Mode",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.podium.toggle",
        "title": "Toggle Podium Mode",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.podium.dashboard",
        "title": "Show Team Dashboard",
        "icon": "$(dashboard)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.hud.focus",
        "title": "Show HUD",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.hud.refresh",
        "title": "Refresh HUD",
        "icon": "$(refresh)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.conversation.focus",
        "title": "Show Team Conversation",
        "icon": "$(comment-discussion)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.conversation.openLatest",
        "title": "Open Latest Team Conversation",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.history.focus",
        "title": "Show Team Session History",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.history.refresh",
        "title": "Refresh History",
        "icon": "$(refresh)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.ccg.focus",
        "title": "Show CCG",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.ccg.refresh",
        "title": "Refresh CCG",
        "icon": "$(refresh)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.ccg.openPair",
        "title": "Open CCG Pair",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.ccg.rerun",
        "title": "Rerun CCG",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.system.registerGateway",
        "title": "Register OpenClaw Gateway",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.system.copyGatewayUrl",
        "title": "Copy Gateway URL",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.system.rotateGatewayToken",
        "title": "Rotate Gateway Token",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.system.openGatewayConfig",
        "title": "Open Gateway Config",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.system.installWorkerPermissions",
        "title": "Install Worker Permissions",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.system.installGeminiAutoApprove",
        "title": "Install Gemini Auto-Approve",
        "category": "Claude"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-code-launcher",
          "title": "Claude Code",
          "icon": "./icons/claude-robot.svg"
        }
      ]
    },
    "views": {
      "claude-code-launcher": [
        {
          "id": "claudeCodeLauncher.sessionList",
          "name": "%sessions%"
        },
        {
          "id": "claudeCodeLauncher.teamsOrchestration",
          "name": "Teams · Orchestration",
          "when": "claudeCodeLauncher.podiumModeActive"
        },
        {
          "id": "claudeCodeLauncher.hudPanel",
          "name": "HUD",
          "when": "claudeCodeLauncher.podiumModeActive"
        },
        {
          "id": "claudeCodeLauncher.historyPanel",
          "name": "Session History",
          "when": "claudeCodeLauncher.podiumModeActive"
        },
        {
          "id": "claudeCodeLauncher.ccgPanel",
          "name": "CCG",
          "when": "claudeCodeLauncher.podiumModeActive"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claudeCodeLauncher.sessionList",
        "contents": "%noSessions%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "claudeCodeLauncher.open",
          "group": "navigation@0"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeCodeLauncher.moveToGroup",
          "when": "view == claudeCodeLauncher.sessionList && (viewItem == session || viewItem == subSession)",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.trashSession",
          "when": "view == claudeCodeLauncher.sessionList && (viewItem == session || viewItem == subSession)",
          "group": "inline@2"
        },
        {
          "command": "claudeCodeLauncher.restoreSession",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == trashed",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.renameGroup",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == customGroup",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.deleteGroup",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == customGroup",
          "group": "inline@2"
        },
        {
          "command": "claudeCodeLauncher.emptyTrash",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == trashGroup",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.moveSessionUp",
          "when": "view == claudeCodeLauncher.sessionList && (viewItem == session || viewItem == subSession)",
          "group": "1_order@1"
        },
        {
          "command": "claudeCodeLauncher.moveSessionDown",
          "when": "view == claudeCodeLauncher.sessionList && (viewItem == session || viewItem == subSession)",
          "group": "1_order@2"
        },
        {
          "command": "claudeCodeLauncher.moveUnderSession",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == session",
          "group": "2_nest@1"
        },
        {
          "command": "claudeCodeLauncher.removeSessionParent",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == subSession",
          "group": "2_nest@2"
        },
        {
          "command": "claudeCodeLauncher.moveGroupUp",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == customGroup",
          "group": "1_order@1"
        },
        {
          "command": "claudeCodeLauncher.moveGroupDown",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == customGroup",
          "group": "1_order@2"
        },
        {
          "command": "claudeCodeLauncher.session.openDir",
          "when": "view == claudeCodeLauncher.historyPanel && (viewItem == historyEntry || viewItem == historyEntryActive)",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.podium.worker.add",
          "when": "view == claudeCodeLauncher.teamsOrchestration && viewItem == podiumLiveTeam",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.podium.worker.remove",
          "when": "view == claudeCodeLauncher.teamsOrchestration && viewItem == podiumWorker",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.podium.worker.rename",
          "when": "view == claudeCodeLauncher.teamsOrchestration && viewItem == podiumWorker",
          "group": "inline@2"
        },
        {
          "command": "claudeCodeLauncher.podium.snapshot.save",
          "when": "view == claudeCodeLauncher.teamsOrchestration && viewItem == podiumLiveTeam",
          "group": "inline@2"
        },
        {
          "command": "claudeCodeLauncher.podium.dissolve",
          "when": "view == claudeCodeLauncher.teamsOrchestration && viewItem == podiumLiveTeam",
          "group": "inline@3"
        },
        {
          "command": "claudeCodeLauncher.podium.pause",
          "when": "view == claudeCodeLauncher.teamsOrchestration && viewItem == podiumLiveTeam",
          "group": "1_ping_pong@1"
        },
        {
          "command": "claudeCodeLauncher.podium.resume",
          "when": "view == claudeCodeLauncher.teamsOrchestration && viewItem == podiumLiveTeam",
          "group": "1_ping_pong@2"
        },
        {
          "command": "claudeCodeLauncher.podium.resetRound",
          "when": "view == claudeCodeLauncher.teamsOrchestration && viewItem == podiumLiveTeam",
          "group": "1_ping_pong@3"
        }
      ],
      "view/title": [
        {
          "command": "claudeCodeLauncher.open",
          "group": "navigation@1",
          "when": "view == claudeCodeLauncher.sessionList"
        },
        {
          "command": "claudeCodeLauncher.refreshSessions",
          "group": "navigation@2",
          "when": "view == claudeCodeLauncher.sessionList"
        },
        {
          "command": "claudeCodeLauncher.podium.orchestrate",
          "group": "navigation@0",
          "when": "view == claudeCodeLauncher.teamsOrchestration"
        },
        {
          "command": "claudeCodeLauncher.podium.orchestrate.resume",
          "group": "navigation@1",
          "when": "view == claudeCodeLauncher.teamsOrchestration"
        },
        {
          "command": "claudeCodeLauncher.podium.snapshot.load",
          "group": "navigation@2",
          "when": "view == claudeCodeLauncher.teamsOrchestration"
        },
        {
          "command": "claudeCodeLauncher.podium.snapshot.rename",
          "group": "navigation@3",
          "when": "view == claudeCodeLauncher.teamsOrchestration"
        },
        {
          "command": "claudeCodeLauncher.session.filter",
          "group": "navigation@9",
          "when": "view == claudeCodeLauncher.teamsOrchestration"
        },
        {
          "command": "claudeCodeLauncher.podium.dashboard",
          "group": "navigation@1",
          "when": "view == claudeCodeLauncher.hudPanel"
        },
        {
          "command": "claudeCodeLauncher.hud.refresh",
          "group": "navigation@2",
          "when": "view == claudeCodeLauncher.hudPanel"
        },
        {
          "command": "claudeCodeLauncher.history.refresh",
          "group": "navigation@1",
          "when": "view == claudeCodeLauncher.historyPanel"
        },
        {
          "command": "claudeCodeLauncher.ccg.refresh",
          "group": "navigation@1",
          "when": "view == claudeCodeLauncher.ccgPanel"
        }
      ]
    },
    "configuration": {
      "title": "Podium CLI Launcher for Claude",
      "properties": {
        "claudeCodeLauncher.defaultTheme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "midnight",
            "ocean",
            "forest",
            "sunset",
            "aurora",
            "warm"
          ],
          "enumDescriptions": [
            "IDE default theme",
            "Midnight — deep purple (#1c1740)",
            "Ocean — deep blue (#0c2240)",
            "Forest — deep green (#0e2810)",
            "Sunset — warm orange (#2a1510)",
            "Aurora — violet (#160e2e)",
            "Warm — warm brown (#241c10)"
          ],
          "description": "Default background theme for new terminals."
        },
        "claudeCodeLauncher.defaultFontSize": {
          "type": "number",
          "default": 11,
          "minimum": 8,
          "maximum": 22,
          "description": "Default font size (px) for the terminal. Range: 8–22."
        },
        "claudeCodeLauncher.defaultFontFamily": {
          "type": "string",
          "default": "\"D2Coding\", \"D2Coding ligature\", Consolas, monospace",
          "description": "Font family for the terminal. Use CSS font-family syntax."
        },
        "claudeCodeLauncher.soundEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable notification sound when a task completes."
        },
        "claudeCodeLauncher.particlesEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable background particle effects."
        },
        "claudeCodeLauncher.autoEffortMax": {
          "type": "boolean",
          "default": false,
          "description": "Automatically send '/effort max' the first time each session becomes idle. Useful to ensure max effort after reload window restores sessions."
        },
        "claudeCodeLauncher.pasteToFileThreshold": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "description": "Characters above which pasted text is saved to a temp file and referenced via @path to avoid PTY write truncation on Ink/ConPTY line-editors. Set to 0 to disable."
        },
        "claudeCodeLauncher.pasteTableAsMarkdown": {
          "type": "boolean",
          "default": true,
          "description": "When clipboard text is a tab-separated table (e.g. Excel selection), auto-convert it to a Markdown table on paste. Text takes priority over image data, so Excel selections no longer paste as PNG."
        },
        "claudeCodeLauncher.customSlashCommands": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "cmd": {
                "type": "string",
                "description": "Slash command (e.g. /wrap-up)"
              },
              "desc": {
                "type": "string",
                "description": "Description shown in dropdown"
              }
            },
            "required": [
              "cmd",
              "desc"
            ]
          },
          "description": "Custom slash commands for the autocomplete dropdown. Shareable as JSON."
        },
        "claudeCodeLauncher.customButtons": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Button label"
              },
              "command": {
                "type": "string",
                "description": "Slash command to execute (e.g. /wrap-up)"
              }
            },
            "required": [
              "label",
              "command"
            ]
          },
          "description": "Custom buttons in the input panel. Each button has a label and a slash command."
        },
        "claudeCodeLauncher.fileAssociations": {
          "type": "object",
          "default": {
            ".csv": "excel",
            ".xlsx": "excel",
            ".xls": "excel",
            ".pptx": "excel",
            ".docx": "system",
            ".pdf": "system",
            ".html": "browser",
            ".htm": "browser",
            ".md": "obsidian",
            ".png": "system",
            ".jpg": "system",
            ".gif": "system",
            ".svg": "system"
          },
          "description": "File extension → open method. Values: 'editor' (IDE), 'system' (OS default), 'obsidian', 'browser', 'excel', or full app path."
        },
        "claudeCodeLauncher.orchestration.claudeCommand": {
          "type": "string",
          "default": "",
          "description": "Override path to the `claude` CLI for orchestration. Empty = auto-detect."
        }
      }
    },
    "keybindings": [
      {
        "command": "claudeCodeLauncher.open",
        "key": "ctrl+shift+;",
        "mac": "cmd+shift+;"
      }
    ]
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./ && node esbuild.webview.config.mjs",
    "build:ts": "tsc -p ./",
    "build:webview": "node esbuild.webview.config.mjs",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "probe:pty": "node scripts/probe/pty-smoke.js",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "lint": "tsc -p ./ --noEmit",
    "build:test": "tsc -p ./tsconfig.test.json",
    "test": "npm run build:test && node --test .test-out/test/unit/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0",
    "esbuild": "^0.21.0"
  }
}
