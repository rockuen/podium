{
  "name": "cli-launcher-for-claude",
  "displayName": "CLI Launcher for Claude",
  "description": "Run Claude Code CLI in a Webview tab with status icons, session management, and rich terminal features.",
  "version": "2.6.1",
  "publisher": "rockuen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rockuen/cli-launcher-for-claude"
  },
  "icon": "icons/icon-128.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeCodeLauncher.open",
        "title": "Open Claude Code",
        "icon": {
          "light": "./icons/claude-robot.svg",
          "dark": "./icons/claude-robot.svg"
        },
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.renameTab",
        "title": "Rename Claude Code Tab",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.refreshSessions",
        "title": "%refreshSessions%",
        "icon": "$(refresh)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.resumeSession",
        "title": "%resumeSession%",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveToGroup",
        "title": "Move to Group...",
        "icon": "$(folder)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.renameGroup",
        "title": "Rename Group",
        "icon": "$(edit)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.deleteGroup",
        "title": "Delete Group",
        "icon": "$(trash)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.trashSession",
        "title": "Delete",
        "icon": "$(trash)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.restoreSession",
        "title": "Restore",
        "icon": "$(history)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.emptyTrash",
        "title": "Empty Trash",
        "icon": "$(close-all)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveSessionUp",
        "title": "Move Up",
        "icon": "$(arrow-up)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveSessionDown",
        "title": "Move Down",
        "icon": "$(arrow-down)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveUnderSession",
        "title": "Nest Under Session...",
        "icon": "$(list-tree)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.removeSessionParent",
        "title": "Unnest (Move to Top Level)",
        "icon": "$(arrow-left)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveGroupUp",
        "title": "Move Group Up",
        "icon": "$(arrow-up)",
        "category": "Claude"
      },
      {
        "command": "claudeCodeLauncher.moveGroupDown",
        "title": "Move Group Down",
        "icon": "$(arrow-down)",
        "category": "Claude"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-code-launcher",
          "title": "Claude Code",
          "icon": "./icons/claude-robot.svg"
        }
      ]
    },
    "views": {
      "claude-code-launcher": [
        {
          "id": "claudeCodeLauncher.sessionList",
          "name": "%sessions%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claudeCodeLauncher.sessionList",
        "contents": "%noSessions%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "claudeCodeLauncher.open",
          "group": "navigation@0"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeCodeLauncher.moveToGroup",
          "when": "view == claudeCodeLauncher.sessionList && (viewItem == session || viewItem == subSession)",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.trashSession",
          "when": "view == claudeCodeLauncher.sessionList && (viewItem == session || viewItem == subSession)",
          "group": "inline@2"
        },
        {
          "command": "claudeCodeLauncher.restoreSession",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == trashed",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.renameGroup",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == customGroup",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.deleteGroup",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == customGroup",
          "group": "inline@2"
        },
        {
          "command": "claudeCodeLauncher.emptyTrash",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == trashGroup",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeLauncher.moveSessionUp",
          "when": "view == claudeCodeLauncher.sessionList && (viewItem == session || viewItem == subSession)",
          "group": "1_order@1"
        },
        {
          "command": "claudeCodeLauncher.moveSessionDown",
          "when": "view == claudeCodeLauncher.sessionList && (viewItem == session || viewItem == subSession)",
          "group": "1_order@2"
        },
        {
          "command": "claudeCodeLauncher.moveUnderSession",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == session",
          "group": "2_nest@1"
        },
        {
          "command": "claudeCodeLauncher.removeSessionParent",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == subSession",
          "group": "2_nest@2"
        },
        {
          "command": "claudeCodeLauncher.moveGroupUp",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == customGroup",
          "group": "1_order@1"
        },
        {
          "command": "claudeCodeLauncher.moveGroupDown",
          "when": "view == claudeCodeLauncher.sessionList && viewItem == customGroup",
          "group": "1_order@2"
        }
      ],
      "view/title": [
        {
          "command": "claudeCodeLauncher.open",
          "group": "navigation@1",
          "when": "view == claudeCodeLauncher.sessionList"
        },
        {
          "command": "claudeCodeLauncher.refreshSessions",
          "group": "navigation@2",
          "when": "view == claudeCodeLauncher.sessionList"
        }
      ]
    },
    "configuration": {
      "title": "CLI Launcher for Claude",
      "properties": {
        "claudeCodeLauncher.defaultTheme": {
          "type": "string",
          "default": "default",
          "enum": ["default", "midnight", "ocean", "forest", "sunset", "aurora", "warm"],
          "enumDescriptions": [
            "IDE default theme",
            "Midnight — deep purple (#1c1740)",
            "Ocean — deep blue (#0c2240)",
            "Forest — deep green (#0e2810)",
            "Sunset — warm orange (#2a1510)",
            "Aurora — violet (#160e2e)",
            "Warm — warm brown (#241c10)"
          ],
          "description": "Default background theme for new terminals."
        },
        "claudeCodeLauncher.defaultFontSize": {
          "type": "number",
          "default": 11,
          "minimum": 8,
          "maximum": 22,
          "description": "Default font size (px) for the terminal. Range: 8–22."
        },
        "claudeCodeLauncher.defaultFontFamily": {
          "type": "string",
          "default": "\"D2Coding\", \"D2Coding ligature\", Consolas, monospace",
          "description": "Font family for the terminal. Use CSS font-family syntax."
        },
        "claudeCodeLauncher.soundEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable notification sound when a task completes."
        },
        "claudeCodeLauncher.particlesEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable background particle effects."
        },
        "claudeCodeLauncher.pasteToFileThreshold": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "description": "Characters above which pasted text is saved to a temp file and referenced via @path to avoid PTY write truncation on Ink/ConPTY line-editors. Set to 0 to disable."
        },
        "claudeCodeLauncher.pasteTableAsMarkdown": {
          "type": "boolean",
          "default": true,
          "description": "When clipboard text is a tab-separated table (e.g. Excel selection), auto-convert it to a Markdown table on paste. Text takes priority over image data, so Excel selections no longer paste as PNG."
        },
        "claudeCodeLauncher.customSlashCommands": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "cmd": { "type": "string", "description": "Slash command (e.g. /wrap-up)" },
              "desc": { "type": "string", "description": "Description shown in dropdown" }
            },
            "required": ["cmd", "desc"]
          },
          "description": "Custom slash commands for the autocomplete dropdown. Shareable as JSON."
        },
        "claudeCodeLauncher.customButtons": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string", "description": "Button label" },
              "command": { "type": "string", "description": "Slash command to execute (e.g. /wrap-up)" }
            },
            "required": ["label", "command"]
          },
          "description": "Custom buttons in the input panel. Each button has a label and a slash command."
        },
        "claudeCodeLauncher.fileAssociations": {
          "type": "object",
          "default": {
            ".csv": "excel",
            ".xlsx": "excel",
            ".xls": "excel",
            ".pptx": "excel",
            ".docx": "system",
            ".pdf": "system",
            ".html": "browser",
            ".htm": "browser",
            ".md": "obsidian",
            ".png": "system",
            ".jpg": "system",
            ".gif": "system",
            ".svg": "system"
          },
          "description": "File extension → open method. Values: 'editor' (IDE), 'system' (OS default), 'obsidian', 'browser', 'excel', or full app path."
        }
      }
    },
    "keybindings": [
      {
        "command": "claudeCodeLauncher.open",
        "key": "ctrl+shift+;",
        "mac": "cmd+shift+;"
      }
    ]
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0"
  }
}
